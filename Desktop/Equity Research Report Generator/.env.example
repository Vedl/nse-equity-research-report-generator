# Copy this file to .env for local overrides (never commit .env).
# Railway: set these as environment variables in the Railway project dashboard.

# CORS — comma-separated list of allowed frontend origins.
# Use "*" for local development (the default when unset).
# In production, set this to your Vercel frontend URL, e.g.:
#   ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=*

# Port — Railway injects $PORT automatically; only set locally if you need
# a non-default port.
# PORT=8000
